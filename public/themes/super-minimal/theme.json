{
  "schema": 1,
  "version": 10,
  "id": "super-minimal",
  "name": "Super Minimal",
  "description": "A quiet text-only theme with no cover area, centered home options, underline selection, and icon-only hints.",
  "inherits": "lyra",
  "constraints": {
    "screenWidth": 480,
    "screenHeight": 800
  },
  "metrics": {
    "headerHeight": 48,
    "tabBarHeight": 36,
    "homeTopPadding": 48,
    "homeCoverHeight": 0,
    "homeCoverTileHeight": 0,
    "homeRecentBooksCount": 1,
    "homeContinueReadingInMenu": true,
    "homeShowContinueReadingHeader": true,
    "homeMenuTopOffset": 0,
    "menuRowHeight": 42,
    "menuSpacing": 6
  },
  "components": {
    "homeRecents": {
      "type": "none"
    },
    "homeMenu": {
      "font": "medium",
      "style": "regular",
      "centeredText": true,
      "centerVertically": true,
      "showIcons": false,
      "drawPanel": false,
      "panelWidth": 360,
      "selectionStyle": "underline",
      "selectionCornerRadius": 6,
      "selectionInset": 18
    },
    "list": {
      "font": "medium",
      "style": "regular",
      "showIcons": false,
      "textGap": 0,
      "selectionStyle": "underline",
      "selectionCornerRadius": 0,
      "selectionFill": false,
      "selectionOutline": false,
      "selectedTextInverted": false,
      "selectionInsetX": 0,
      "selectionInsetY": 0,
      "titleOffsetY": 7,
      "subtitleOffsetY": 30,
      "valueOffsetY": 6,
      "subtitleValueOffsetY": 16,
      "iconOffsetY": 0
    },
    "header": {
      "font": "medium",
      "style": "regular",
      "centeredTitle": true,
      "showDivider": false,
      "titleOffsetY": 0
    },
    "tabBar": {
      "font": "medium",
      "style": "regular",
      "equalWidth": true,
      "selectionStyle": "underline",
      "selectedTextInverted": false,
      "drawDivider": false,
      "horizontalInset": 2
    },
    "buttonHints": {
      "font": "small",
      "style": "regular",
      "buttonWidth": 80,
      "smallButtonHeight": 15,
      "cornerRadius": 6,
      "fill": false,
      "outline": false,
      "drawEmpty": false,
      "shapes": true,
      "shapeSize": 18,
      "textOffsetY": 7
    }
  },
  "screens": {
    "home": {
      "layout": {
        "axis": "column",
        "gap": 0,
        "slots": [
          { "id": "header", "fixed": 48 },
          { "id": "menu", "flex": 1 },
          { "id": "buttons", "fixed": 40 }
        ]
      },
      "widgets": [
        { "slot": "header", "type": "header" },
        {
          "slot": "menu",
          "type": "launcherList",
          "items": [
            { "text": "Continue Reading", "icon": "book", "action": "reader:recent" },
            { "text": "Browse Files", "icon": "folder", "action": "activity:fileBrowser" },
            { "text": "Recent Books", "icon": "recent", "action": "activity:recentBooks" },
            { "text": "Remote Library", "icon": "library", "action": "activity:opds" },
            { "text": "File Transfer", "icon": "transfer", "action": "activity:fileTransfer" },
            { "text": "Settings", "icon": "settings", "action": "activity:settings" }
          ]
        },
        {
          "slot": "buttons",
          "type": "buttonHints",
          "labels": {
            "confirm": "select",
            "previous": "up",
            "next": "down"
          }
        }
      ]
    },
    "fileBrowser": {
      "layout": {
        "axis": "column",
        "gap": 8,
        "slots": [
          { "id": "header", "fixed": 48 },
          { "id": "list", "flex": 1 },
          { "id": "path", "fixed": 14 },
          { "id": "buttons", "fixed": 40 }
        ]
      }
    },
    "recentBooks": {
      "layout": {
        "axis": "column",
        "gap": 8,
        "slots": [
          { "id": "header", "fixed": 48 },
          { "id": "list", "flex": 1 },
          { "id": "buttons", "fixed": 40 }
        ]
      },
      "widgets": [
        { "slot": "list", "type": "list" }
      ]
    },
    "settings": {
      "layout": {
        "axis": "column",
        "gap": 0,
        "slots": [
          { "id": "header", "fixed": 48 },
          { "id": "tabs", "fixed": 36 },
          { "id": "list", "flex": 1 },
          { "id": "buttons", "fixed": 40 }
        ]
      }
    },
    "reader": {
      "layout": {
        "axis": "row",
        "gap": 8,
        "slots": [
          { "id": "bookmark", "fixed": 18 },
          { "id": "battery", "fixed": 38 },
          { "id": "title", "flex": 1 },
          { "id": "clock", "fixed": 42 },
          { "id": "progress", "fixed": 82 }
        ]
      },
      "chrome": {
        "battery": {
          "style": "bar",
          "width": 38,
          "height": 3,
          "offsetY": 1,
          "showPercentage": false
        }
      }
    }
  },
  "extensions": {
    "crossink": {
      "reference": "src/components/themes/minimal"
    }
  }
}
